# Include important top-level files
include README.md
include LICENSE
include pyproject.toml
include requirements.txt

# Include the example data so --example works after pip install
recursive-include examples *.csv

# Include documentation sources
recursive-include docs *.md *.rst *.txt

# Exclude build artifacts and noise
prune docs/_build
global-exclude *.py[cod] __pycache__ *.so *.DS_Store
